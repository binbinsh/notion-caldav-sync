{
  "name": "notion-caldav-sync",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:frontend && wrangler dev --config wrangler.toml",
    "build:frontend": "cd frontend && npm install --ignore-scripts && npm run build",
    "deploy": "wrangler deploy --config wrangler.toml",
    "predeploy:check": "npm run build:frontend && node scripts/predeploy-check.mjs",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.1",
    "@clerk/hono": "^0.1.19",
    "@notionhq/client": "^5.17.0",
    "fast-xml-parser": "^5.7.2",
    "hono": "^4.12.15",
    "ical-generator": "^10.1.0",
    "ical.js": "^2.2.1",
    "tsdav": "^2.1.8",
    "zod": "^4.1.12"
  },
  "overrides": {
    "@clerk/shared": "^4.8.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.42.0"
  }
}
